public/
  images/specimens/                 # Per-specimen photography
  llms.txt                          # LLM-readable site summary
  llms-full.txt                     # Extended LLM context

scripts/
  upload-splats.mjs                 # Convert PLY -> KSPLAT, upload to Vercel Blob
  google-apps-script.js             # Apps Script webhook -> /api/revalidate
