      index.ts
    localities.ts                   # 4 mine localities with coordinates
    index.ts                        # Data aggregation

  lib/
    google-sheets.ts                # Sheets API: fetch/write specimens
    google-drive.ts                 # Drive image URL resolution
    data.ts                         # Data helpers (getSpecimen, etc.)
    utils.ts                        # Shared utilities

  hooks/
    use-cart.tsx                     # Cart state management
